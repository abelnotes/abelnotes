# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# settings.json commonly leaks local machine paths (e.g. cmake.sourceDirectory);
# keep launch.json/tasks.json shareable but never track this one.
.vscode/settings.json

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Claude Code: worktrees, memory, agent transcripts — local only.
# Was previously written as UTF-16 on a single line which git couldn't
# match, leaving these untracked-but-leak-prone if `git add -A` ran.
.claude/

# Audit scratch dirs from the multi-agent review passes.
design_audit/

# Local backups, scratch files, build caches not covered above
HandWriter - Copia/
Testo.txt
**/.kotlin/
/log
native/onenote_bridge/target/
